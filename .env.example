# Safe classroom defaults
DEBUG=false
# Replace this placeholder before real classroom use.
SECRET_KEY=change-me-for-real-use
ALLOWED_HOSTS=localhost,127.0.0.1,[::1],<LAPTOP_LAN_IP>
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://<LAPTOP_LAN_IP>:8000
DATABASE_PATH=/app/data/db.sqlite3
TIME_ZONE=Indian/Antananarivo

# Port hôte du conteneur (defaut : 8010)
TAF_HOST_PORT=8010

# Adresse IP locale du laptop à afficher aux élèves (optionnel)
# Si vide, la page "Accès réseau" tente de détecter l'IP automatiquement.
TAF_LAN_HOST=
