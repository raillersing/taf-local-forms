#!/bin/bash
# TAf Local Forms — Test de charge local (mode safe)
# Simule jusqu'a 100 utilisateurs en lecture seule.
# Usage: scripts/dev/taf-load-smoke [base_url] [concurrency]
#   base_url    : http://localhost:8010 (defaut)
#   concurrency : 100 (defaut)
#
# Mode safe: lectures seulement, ne modifie aucune donnee.

set -euo pipefail

BASE_URL="${1:-http://localhost:8010}"
CONCURRENCY="${2:-100}"

echo "============================================"
echo "  TAf Local Forms — Load Smoke Test"
echo "============================================"
echo "  URL        : $BASE_URL"
echo "  Concurrency: $CONCURRENCY"
echo "  Mode       : READ-ONLY (safe)"
echo "============================================"
echo ""

if ! command -v curl &>/dev/null; then
    echo "ERREUR: curl est requis."
    exit 1
fi

URLS=(
    "/" "/modules/"
    "/modules/module-2/" "/modules/module-3/"
    "/modules/module-4/" "/modules/module-5/"
    "/modules/module-6/" "/modules/module-7/"
    "/module-2/" "/module-3/" "/module-4/"
    "/module-5/" "/module-6/" "/module-7/"
    "/dashboard/"
)

RESULTS_FILE=$(mktemp)
trap 'rm -f "$RESULTS_FILE"' EXIT

TOTAL_REQUESTS=0
START=$(date +%s%N)

for url in "${URLS[@]}"; do
    for ((i=0; i<CONCURRENCY; i++)); do
        TOTAL_REQUESTS=$((TOTAL_REQUESTS + 1))
        (
            t1=$(date +%s%N)
            http_code=$(curl -s -o /dev/null -w "%{http_code}" --connect-timeout 5 --max-time 10 "${BASE_URL}${url}" 2>/dev/null || echo "000")
            t2=$(date +%s%N)
            latency=$(( (t2 - t1) / 1000000 ))
            echo "$http_code $latency" >> "$RESULTS_FILE"
        ) &
    done
    wait
done

wait
END=$(date +%s%N)
DURATION_MS=$(( (END - START) / 1000000 ))

SUCCESS=0
FAIL=0
MIN_LAT=999999
MAX_LAT=0
TOTAL_LAT=0
COUNT=0

while read -r code lat; do
    COUNT=$((COUNT + 1))
    TOTAL_LAT=$((TOTAL_LAT + lat))
    if [ "$lat" -lt "$MIN_LAT" ]; then MIN_LAT=$lat; fi
    if [ "$lat" -gt "$MAX_LAT" ]; then MAX_LAT=$lat; fi
    if [ "$code" = "200" ] || [ "$code" = "302" ] || [ "$code" = "301" ]; then
        SUCCESS=$((SUCCESS + 1))
    else
        FAIL=$((FAIL + 1))
    fi
done < "$RESULTS_FILE"

AVG_LAT=$(( TOTAL_LAT / (COUNT > 0 ? COUNT : 1) ))
RATE=$(echo "scale=2; $SUCCESS * 100 / ($SUCCESS + $FAIL)" | bc 2>/dev/null || echo "N/A")
RPS=$(echo "scale=1; $TOTAL_REQUESTS * 1000 / $DURATION_MS" | bc 2>/dev/null || echo "N/A")

echo ""
echo "============================================"
echo "  Resultats"
echo "============================================"
echo "  Requetes totales : $TOTAL_REQUESTS"
echo "  Succes           : $SUCCESS"
echo "  Echecs           : $FAIL"
echo "  Taux de succes   : ${RATE}%"
echo "  Duree totale     : ${DURATION_MS}ms"
echo "  Latence min      : ${MIN_LAT}ms"
echo "  Latence moyenne  : ${AVG_LAT}ms"
echo "  Latence max      : ${MAX_LAT}ms"
echo "  Requetes/seconde : ${RPS}"
echo "============================================"

if [ "$FAIL" -gt 0 ]; then
    exit 1
fi
