#!/usr/bin/env bash
set -euo pipefail

echo "TAf Graphify status"
if command -v graphify >/dev/null 2>&1; then
  graphify --version || true
else
  echo "graphify not found on PATH"
  echo "Install option: uv tool install graphifyy"
fi

if [ -f "graphify-out/GRAPH_REPORT.md" ]; then
  echo "GRAPH_REPORT.md exists"
else
  echo "No graphify-out/GRAPH_REPORT.md found"
fi

echo "This script does not run graphify extraction."
echo "Never scan .env, backups, dumps, databases, runtime media, or sensitive logs."
